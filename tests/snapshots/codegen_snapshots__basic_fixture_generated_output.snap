import { UniffiObjectBase } from "./runtime/objects.js";



export interface ComponentMetadata {
  namespace: string;
  packageName: string;
  cdylibName: string;
  nodeEngine: string;
  libPathLiteral: string | null;
  bundledPrebuilds: boolean;
  manualLoad: boolean;
}

export declare const componentMetadata: Readonly<ComponentMetadata>;

export { ffiMetadata } from "./fixture-ffi.js";


export interface BlobRecord {
  "name": string;
  "value": Uint8Array;
  "maybe_value": Uint8Array | undefined;
  "chunks": Array<Uint8Array>;
}

export interface TemporalRecord {
  "when": Date;
  "delay_ms": number;
  "maybe_when": Date | undefined;
  "delays_ms": Array<number>;
  "reminders": Map<string, Date>;
}

export declare const Flavor: Readonly<{
  "Vanilla": "Vanilla";
  "Chocolate": "Chocolate";
}>;
export type Flavor = (typeof Flavor)[keyof typeof Flavor];

export interface ScanResultHit {
  tag: "Hit";
  "value": Uint8Array;
}

export interface ScanResultMiss {
  tag: "Miss";
}

export type ScanResult = ScanResultHit | ScanResultMiss;
export declare const ScanResult: Readonly<{
  Hit(value: Uint8Array): ScanResultHit;
  Miss(): ScanResultMiss;
}>;

export declare class FixtureError extends globalThis.Error {
  readonly tag: string;
  protected constructor(tag: string, message?: string);
}

export declare class FixtureErrorMissing extends FixtureError {
  readonly tag: "Missing";
  constructor();
}

export declare class FixtureErrorInvalidState extends FixtureError {
  readonly tag: "InvalidState";
  readonly "message": string;
  constructor(message: string);
}

export declare class FixtureErrorParse extends FixtureError {
  readonly tag: "Parse";
  readonly "message": string;
  constructor(message: string);
}

export declare function echo_byte_map(value: Map<string, Uint8Array>): Map<string, Uint8Array>;

export declare function echo_bytes(value: Uint8Array): Uint8Array;

export declare function echo_duration(delay_ms: number): number;

export declare function echo_record(record: BlobRecord): BlobRecord;

export declare function echo_temporal_record(record: TemporalRecord): TemporalRecord;

export declare function echo_timestamp(when: Date): Date;

export declare class Config extends UniffiObjectBase {
  protected constructor();
  static from_json(json: string): Config;
  value(): string;
}

export declare class Reader extends UniffiObjectBase {
  protected constructor();
  label(): string;
  label_async(): Promise<string>;
}

export declare class ReaderBuilder extends UniffiObjectBase {
  constructor(valid: boolean);
  build(): Promise<Reader>;
}

export declare class Store extends UniffiObjectBase {
  constructor(seed: BlobRecord);
  current(): BlobRecord;
  fetch_async(succeed: boolean): Promise<BlobRecord>;
  flavor(): Flavor;
  inspect(include_payload: boolean): ScanResult;
  replace(next_value: Uint8Array): Uint8Array;
  require_value(present: boolean): Uint8Array;
  schedule(when: Date, delay_ms: number): TemporalRecord;
}
