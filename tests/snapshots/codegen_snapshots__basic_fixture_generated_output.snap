=== fixture.js ===
import koffi from "koffi";


import {

  configureRuntimeHooks,

  ffiFunctions,

  getFfiBindings,

  getFfiTypes,

} from "./fixture-ffi.js";


import {

  createForeignBytes,

  RustBufferValue,

} from "./runtime/ffi-types.js";


import {

  AbstractFfiConverterByteArray,

  FfiConverterArray,

  FfiConverterBool,

  FfiConverterBytes,

  FfiConverterDuration,

  FfiConverterMap,

  FfiConverterOptional,

  FfiConverterString,

  FfiConverterTimestamp,

} from "./runtime/ffi-converters.js";


import {

  UnexpectedEnumCase,

} from "./runtime/errors.js";


import {

  rustCallAsync,

  rustFutureContinuationCallback,

} from "./runtime/async-rust-call.js";


import {

  clearPendingForeignFutures,

} from "./runtime/callbacks.js";


import {

  createObjectConverter,

  createObjectFactory,

  UniffiObjectBase,

} from "./runtime/objects.js";


import {

  UniffiRustCaller,

  createRustCallStatus,

} from "./runtime/rust-call.js";


export const componentMetadata = Object.freeze({
  namespace: "fixture",
  packageName: "fixture-package",
  cdylibName: "fixture_basic",
  nodeEngine: ">=16",
  libPathLiteral: null,
  bundledPrebuilds: false,
  manualLoad: false,
});

export { ffiMetadata } from "./fixture-ffi.js";


function uniffiNotImplemented(member) {
  throw new Error(`${member} is not implemented yet. Koffi-backed bindings are still pending.`);
}

const uniffiTextEncoder = new TextEncoder();
const uniffiTextDecoder = new TextDecoder();
const uniffiSuccessRustCallStatus = createRustCallStatus();
const UNIFFI_MAX_CACHED_RUST_CALL_STATUSES = 32;
const uniffiRustCallStatusPool = [];

function uniffiLiftString(bytes) {
  return uniffiTextDecoder.decode(bytes);
}

function uniffiDecodeRustCallStatus(status) {
  return status == null
    ? uniffiSuccessRustCallStatus
    : koffi.decode(status, 0, "int8_t") === 0
      ? uniffiSuccessRustCallStatus
      : koffi.decode(status, getFfiTypes().RustCallStatus);
}

function uniffiWriteRustCallStatus(status, value) {
  if (
    status != null
    && (
      value.code !== 0
      || value.error_buf.data !== null
      || value.error_buf.len !== 0n
      || value.error_buf.capacity !== 0n
    )
  ) {
    koffi.encode(status, getFfiTypes().RustCallStatus, value);
  }
  return status;
}

function uniffiAcquireRustCallStatus() {
  const status = uniffiRustCallStatusPool.pop();
  if (status != null) {
    return status;
  }
  return koffi.alloc(getFfiTypes().RustCallStatus, 1);
}

function uniffiReleaseRustCallStatus(status) {
  if (status == null) {
    return;
  }

  koffi.encode(status, getFfiTypes().RustCallStatus, uniffiSuccessRustCallStatus);
  if (uniffiRustCallStatusPool.length < UNIFFI_MAX_CACHED_RUST_CALL_STATUSES) {
    uniffiRustCallStatusPool.push(status);
    return;
  }

  koffi.free(status);
}

const uniffiRustCaller = new UniffiRustCaller({
  createStatus: uniffiAcquireRustCallStatus,
  disposeStatus: uniffiReleaseRustCallStatus,
  readStatus: uniffiDecodeRustCallStatus,
  writeStatus: uniffiWriteRustCallStatus,
  liftString: uniffiLiftString,
});

function uniffiFreeRustBuffer(buffer) {
  return uniffiRustCaller.rustCall(
    (status) => ffiFunctions.ffi_fixture_basic_rustbuffer_free(buffer, status),
    { liftString: uniffiLiftString },
  );
}

const uniffiDefaultRustCallOptions = Object.freeze({
  freeRustBuffer: uniffiFreeRustBuffer,
  liftString: uniffiLiftString,
  rustCaller: uniffiRustCaller,
});
const uniffiRustCallOptionsByErrorConverter = new WeakMap();
const uniffiOptionalConverterCache = new WeakMap();
const uniffiArrayConverterCache = new WeakMap();
const uniffiLibraryFunctionCache = new WeakMap();

function uniffiRustCallOptions(errorConverter = undefined) {
  if (errorConverter == null) {
    return uniffiDefaultRustCallOptions;
  }

  if (typeof errorConverter !== "object" && typeof errorConverter !== "function") {
    return Object.freeze({
      errorHandler: (errorBytes) => errorConverter.lift(errorBytes),
      freeRustBuffer: uniffiFreeRustBuffer,
      liftString: uniffiLiftString,
      rustCaller: uniffiRustCaller,
    });
  }

  const cachedOptions = uniffiRustCallOptionsByErrorConverter.get(errorConverter);
  if (cachedOptions != null) {
    return cachedOptions;
  }

  const options = Object.freeze({
    errorHandler: (errorBytes) => errorConverter.lift(errorBytes),
    freeRustBuffer: uniffiFreeRustBuffer,
    liftString: uniffiLiftString,
    rustCaller: uniffiRustCaller,
  });
  uniffiRustCallOptionsByErrorConverter.set(errorConverter, options);
  return options;
}

function uniffiOptionalConverter(innerConverter) {
  let converter = uniffiOptionalConverterCache.get(innerConverter);
  if (converter == null) {
    converter = new FfiConverterOptional(innerConverter);
    uniffiOptionalConverterCache.set(innerConverter, converter);
  }
  return converter;
}

function uniffiArrayConverter(innerConverter) {
  let converter = uniffiArrayConverterCache.get(innerConverter);
  if (converter == null) {
    converter = new FfiConverterArray(innerConverter);
    uniffiArrayConverterCache.set(innerConverter, converter);
  }
  return converter;
}

function uniffiGetCachedLibraryFunction(cacheKey, create) {
  const bindings = getFfiBindings();
  const library = bindings.library;
  let libraryCache = uniffiLibraryFunctionCache.get(library);
  if (libraryCache == null) {
    libraryCache = new Map();
    uniffiLibraryFunctionCache.set(library, libraryCache);
  }

  let cachedFunction = libraryCache.get(cacheKey);
  if (cachedFunction == null) {
    cachedFunction = create(bindings);
    libraryCache.set(cacheKey, cachedFunction);
  }
  return cachedFunction;
}

function uniffiCopyIntoRustBuffer(bytes) {
  return uniffiRustCaller.rustCall(
    (status) => ffiFunctions.ffi_fixture_basic_rustbuffer_from_bytes(createForeignBytes(bytes), status),
    uniffiRustCallOptions(),
  );
}

function uniffiLowerString(value) {
  return uniffiCopyIntoRustBuffer(uniffiTextEncoder.encode(value));
}

function uniffiLiftStringFromRustBuffer(value) {
  return uniffiLiftString(new RustBufferValue(value).consumeIntoUint8Array(uniffiFreeRustBuffer));
}

function uniffiLowerBytes(value) {
  return uniffiCopyIntoRustBuffer(value);
}

function uniffiLiftBytesFromRustBuffer(value) {
  return new RustBufferValue(value).consumeIntoUint8Array(uniffiFreeRustBuffer);
}

function uniffiLowerIntoRustBuffer(converter, value) {
  return uniffiCopyIntoRustBuffer(converter.lower(value));
}

function uniffiLiftFromRustBuffer(converter, value) {
  return converter.lift(uniffiLiftBytesFromRustBuffer(value));
}

function uniffiRequireRecordObject(typeName, value) {
  if (typeof value !== "object" || value == null) {
    throw new TypeError(`${typeName} values must be non-null objects.`);
  }
  return value;
}

function uniffiRequireFlatEnumValue(enumValues, typeName, value) {
  for (const enumValue of Object.values(enumValues)) {
    if (enumValue === value) {
      return enumValue;
    }
  }
  throw new TypeError(`${typeName} values must be one of ${Object.values(enumValues).map((item) => JSON.stringify(item)).join(", ")}.`);
}

function uniffiRequireTaggedEnumValue(typeName, value) {
  const enumValue = uniffiRequireRecordObject(typeName, value);
  if (typeof enumValue.tag !== "string") {
    throw new TypeError(`${typeName} values must be tagged objects with a string tag field.`);
  }
  return enumValue;
}

function uniffiNotImplementedConverter(typeName) {
  const fail = (member) => {
    throw new Error(`${typeName} converter ${member} is not implemented yet.`);
  };
  return Object.freeze({
    lower() {
      return fail("lower");
    },
    lift() {
      return fail("lift");
    },
    write() {
      return fail("write");
    },
    read() {
      return fail("read");
    },
    allocationSize() {
      return fail("allocationSize");
    },
  });
}

let uniffiRustFutureContinuationPointer = null;

function uniffiGetRustFutureContinuationPointer() {
  if (uniffiRustFutureContinuationPointer == null) {
    const bindings = getFfiBindings();
    uniffiRustFutureContinuationPointer = koffi.register(
      rustFutureContinuationCallback,
      koffi.pointer(bindings.ffiCallbacks.RustFutureContinuationCallback),
    );
  }
  return uniffiRustFutureContinuationPointer;
}

export const Flavor = Object.freeze({
  "Vanilla": "Vanilla",
  "Chocolate": "Chocolate",
});

export const ScanResult = Object.freeze({
  Hit(value) {
    return Object.freeze({
      tag: "Hit",
      "value": value,
    });
  },
  Miss() {
    return Object.freeze({
      tag: "Miss",
    });
  },
});

export class FixtureError extends globalThis.Error {
  constructor(tag, message = tag) {
    super(message);
    this.name = "FixtureError";
    this.tag = tag;
  }
}

export class FixtureErrorMissing extends FixtureError {
  constructor() {
    super("Missing");
    this.name = "FixtureErrorMissing";
  }
}

export class FixtureErrorInvalidState extends FixtureError {
  constructor(message) {
    super("InvalidState");
    this.name = "FixtureErrorInvalidState";
    this["message"] = message;
  }
}

export class FixtureErrorParse extends FixtureError {
  constructor(message) {
    super("Parse");
    this.name = "FixtureErrorParse";
    this["message"] = message;
  }
}

const FfiConverterBlobRecord = new (class extends AbstractFfiConverterByteArray {
  allocationSize(value) {
    const recordValue = uniffiRequireRecordObject("BlobRecord", value);
    return FfiConverterString.allocationSize(recordValue["name"]) + FfiConverterBytes.allocationSize(recordValue["value"]) + uniffiOptionalConverter(FfiConverterBytes).allocationSize(recordValue["maybe_value"]) + uniffiArrayConverter(FfiConverterBytes).allocationSize(recordValue["chunks"]);
  }

  write(value, writer) {
    const recordValue = uniffiRequireRecordObject("BlobRecord", value);
    FfiConverterString.write(recordValue["name"], writer);
    FfiConverterBytes.write(recordValue["value"], writer);
    uniffiOptionalConverter(FfiConverterBytes).write(recordValue["maybe_value"], writer);
    uniffiArrayConverter(FfiConverterBytes).write(recordValue["chunks"], writer);
  }

  read(reader) {
    return {
      "name": FfiConverterString.read(reader),
      "value": FfiConverterBytes.read(reader),
      "maybe_value": uniffiOptionalConverter(FfiConverterBytes).read(reader),
      "chunks": uniffiArrayConverter(FfiConverterBytes).read(reader),
    };
  }
})();
const FfiConverterTemporalRecord = new (class extends AbstractFfiConverterByteArray {
  allocationSize(value) {
    const recordValue = uniffiRequireRecordObject("TemporalRecord", value);
    return FfiConverterTimestamp.allocationSize(recordValue["when"]) + FfiConverterDuration.allocationSize(recordValue["delay_ms"]) + uniffiOptionalConverter(FfiConverterTimestamp).allocationSize(recordValue["maybe_when"]) + uniffiArrayConverter(FfiConverterDuration).allocationSize(recordValue["delays_ms"]) + new FfiConverterMap(FfiConverterString, FfiConverterTimestamp).allocationSize(recordValue["reminders"]);
  }

  write(value, writer) {
    const recordValue = uniffiRequireRecordObject("TemporalRecord", value);
    FfiConverterTimestamp.write(recordValue["when"], writer);
    FfiConverterDuration.write(recordValue["delay_ms"], writer);
    uniffiOptionalConverter(FfiConverterTimestamp).write(recordValue["maybe_when"], writer);
    uniffiArrayConverter(FfiConverterDuration).write(recordValue["delays_ms"], writer);
    new FfiConverterMap(FfiConverterString, FfiConverterTimestamp).write(recordValue["reminders"], writer);
  }

  read(reader) {
    return {
      "when": FfiConverterTimestamp.read(reader),
      "delay_ms": FfiConverterDuration.read(reader),
      "maybe_when": uniffiOptionalConverter(FfiConverterTimestamp).read(reader),
      "delays_ms": uniffiArrayConverter(FfiConverterDuration).read(reader),
      "reminders": new FfiConverterMap(FfiConverterString, FfiConverterTimestamp).read(reader),
    };
  }
})();
const FfiConverterFlavor = new (class extends AbstractFfiConverterByteArray {
  allocationSize(value) {
    uniffiRequireFlatEnumValue(Flavor, "Flavor", value);
    return 4;
  }

  write(value, writer) {
    const enumValue = uniffiRequireFlatEnumValue(Flavor, "Flavor", value);
    switch (enumValue) {
      case Flavor["Vanilla"]:
        writer.writeInt32(1);
        return;
      case Flavor["Chocolate"]:
        writer.writeInt32(2);
        return;
      default:
        throw new UnexpectedEnumCase(`Unexpected Flavor case ${String(enumValue)}.`);
    }
  }

  read(reader) {
    const enumTag = reader.readInt32();
    switch (enumTag) {
      case 1:
        return Flavor["Vanilla"];
      case 2:
        return Flavor["Chocolate"];
      default:
        throw new UnexpectedEnumCase(`Unexpected Flavor case ${String(enumTag)}.`);
    }
  }
})();
const FfiConverterScanResult = new (class extends AbstractFfiConverterByteArray {
  allocationSize(value) {
    const enumValue = uniffiRequireTaggedEnumValue("ScanResult", value);
    switch (enumValue.tag) {
      case "Hit":
        return 4 + FfiConverterBytes.allocationSize(enumValue["value"]);
      case "Miss":
        return 4;
      default:
        throw new UnexpectedEnumCase(`Unexpected ScanResult case ${String(enumValue.tag)}.`);
    }
  }

  write(value, writer) {
    const enumValue = uniffiRequireTaggedEnumValue("ScanResult", value);
    switch (enumValue.tag) {
      case "Hit":
        writer.writeInt32(1);
        FfiConverterBytes.write(enumValue["value"], writer);
        return;
      case "Miss":
        writer.writeInt32(2);
        return;
      default:
        throw new UnexpectedEnumCase(`Unexpected ScanResult case ${String(enumValue.tag)}.`);
    }
  }

  read(reader) {
    const enumTag = reader.readInt32();
    switch (enumTag) {
      case 1:
        return ScanResult.Hit(FfiConverterBytes.read(reader));
      case 2:
        return ScanResult.Miss();
      default:
        throw new UnexpectedEnumCase(`Unexpected ScanResult case ${String(enumTag)}.`);
    }
  }
})();
const FfiConverterFixtureError = new (class extends AbstractFfiConverterByteArray {
  allocationSize(value) {
    if (value instanceof FixtureErrorMissing) {
      return 4;
    }
    if (value instanceof FixtureErrorInvalidState) {
      return 4 + FfiConverterString.allocationSize(value["message"]);
    }
    if (value instanceof FixtureErrorParse) {
      return 4 + FfiConverterString.allocationSize(value["message"]);
    }
    throw new TypeError("FixtureError values must be instances of FixtureErrorMissing, FixtureErrorInvalidState, FixtureErrorParse.");
  }

  write(value, writer) {
    if (value instanceof FixtureErrorMissing) {
      writer.writeInt32(1);
      return;
    }
    if (value instanceof FixtureErrorInvalidState) {
      writer.writeInt32(2);
      FfiConverterString.write(value["message"], writer);
      return;
    }
    if (value instanceof FixtureErrorParse) {
      writer.writeInt32(3);
      FfiConverterString.write(value["message"], writer);
      return;
    }
    throw new TypeError("FixtureError values must be instances of FixtureErrorMissing, FixtureErrorInvalidState, FixtureErrorParse.");
  }

  read(reader) {
    const enumTag = reader.readInt32();
    switch (enumTag) {
      case 1:
        return new FixtureErrorMissing();
      case 2:
        return new FixtureErrorInvalidState(FfiConverterString.read(reader));
      case 3:
        return new FixtureErrorParse(FfiConverterString.read(reader));
      default:
        throw new UnexpectedEnumCase(`Unexpected FixtureError case ${String(enumTag)}.`);
    }
  }
})();

const uniffiRegisteredCallbackPointers = [];
const uniffiRegisteredCallbackVtables = [];

function uniffiRegisterCallbackVtables(bindings) {
}

function uniffiUnregisterCallbackVtables() {
  clearPendingForeignFutures();
  while (uniffiRegisteredCallbackPointers.length > 0) {
    koffi.unregister(uniffiRegisteredCallbackPointers.pop());
  }
  uniffiRegisteredCallbackVtables.length = 0;
}

configureRuntimeHooks({
  onLoad(bindings) {
    void bindings;
  },
  onUnload() {
    if (uniffiRustFutureContinuationPointer != null) {
      koffi.unregister(uniffiRustFutureContinuationPointer);
      uniffiRustFutureContinuationPointer = null;
    }
    uniffiUnregisterCallbackVtables();
  },
});

export function echo_byte_map(value) {
    const loweredValue = uniffiLowerIntoRustBuffer(new FfiConverterMap(FfiConverterString, FfiConverterBytes), value);
  const uniffiResult = uniffiRustCaller.rustCall(
    (status) => ffiFunctions.uniffi_fixture_basic_fn_func_echo_byte_map(loweredValue, status),
    uniffiRustCallOptions(),
  );
  return uniffiLiftFromRustBuffer(new FfiConverterMap(FfiConverterString, FfiConverterBytes), uniffiResult);
}

export function echo_bytes(value) {
    const loweredValue = uniffiLowerIntoRustBuffer(FfiConverterBytes, value);
  const uniffiResult = uniffiRustCaller.rustCall(
    (status) => ffiFunctions.uniffi_fixture_basic_fn_func_echo_bytes(loweredValue, status),
    uniffiRustCallOptions(),
  );
  return uniffiLiftFromRustBuffer(FfiConverterBytes, uniffiResult);
}

export function echo_duration(delay_ms) {
    const loweredDelayMs = uniffiLowerIntoRustBuffer(FfiConverterDuration, delay_ms);
  const uniffiResult = uniffiRustCaller.rustCall(
    (status) => ffiFunctions.uniffi_fixture_basic_fn_func_echo_duration(loweredDelayMs, status),
    uniffiRustCallOptions(),
  );
  return uniffiLiftFromRustBuffer(FfiConverterDuration, uniffiResult);
}

export function echo_record(record) {
    const loweredRecord = uniffiLowerIntoRustBuffer(FfiConverterBlobRecord, record);
  const uniffiResult = uniffiRustCaller.rustCall(
    (status) => ffiFunctions.uniffi_fixture_basic_fn_func_echo_record(loweredRecord, status),
    uniffiRustCallOptions(),
  );
  return uniffiLiftFromRustBuffer(FfiConverterBlobRecord, uniffiResult);
}

export function echo_temporal_record(record) {
    const loweredRecord = uniffiLowerIntoRustBuffer(FfiConverterTemporalRecord, record);
  const uniffiResult = uniffiRustCaller.rustCall(
    (status) => ffiFunctions.uniffi_fixture_basic_fn_func_echo_temporal_record(loweredRecord, status),
    uniffiRustCallOptions(),
  );
  return uniffiLiftFromRustBuffer(FfiConverterTemporalRecord, uniffiResult);
}

export function echo_timestamp(when) {
    const loweredWhen = uniffiLowerIntoRustBuffer(FfiConverterTimestamp, when);
  const uniffiResult = uniffiRustCaller.rustCall(
    (status) => ffiFunctions.uniffi_fixture_basic_fn_func_echo_timestamp(loweredWhen, status),
    uniffiRustCallOptions(),
  );
  return uniffiLiftFromRustBuffer(FfiConverterTimestamp, uniffiResult);
}

export class Config extends UniffiObjectBase {
  constructor() {
    super();
    return uniffiNotImplemented("Config.constructor");
  }

  static from_json(json) {
    const loweredJson = uniffiLowerString(json);
    const pointer = uniffiRustCaller.rustCall(
      (status) => ffiFunctions.uniffi_fixture_basic_fn_constructor_config_from_json(loweredJson, status),
      uniffiRustCallOptions(FfiConverterFixtureError),
    );
    return uniffiConfigObjectFactory.create(pointer);
  }

  value() {
    const loweredSelf = uniffiConfigObjectFactory.cloneHandle(this);
    const ffiMethod =
      uniffiConfigObjectFactory.usesGenericAbi(this)
        ? ffiFunctions.uniffi_fixture_basic_fn_method_config_value_generic_abi
        : ffiFunctions.uniffi_fixture_basic_fn_method_config_value;
    const uniffiResult = uniffiRustCaller.rustCall(
      (status) => ffiMethod(loweredSelf, status),
      uniffiRustCallOptions(),
    );
    return uniffiLiftStringFromRustBuffer(uniffiResult);
  }
}

const uniffiConfigObjectFactory = createObjectFactory({
  typeName: "Config",
  createInstance: () => Object.create(Config.prototype),
  cloneFreeUsesUniffiHandle: true,
  cloneHandleGeneric(handle) {
    return uniffiRustCaller.rustCall(
      (status) => ffiFunctions.uniffi_fixture_basic_fn_clone_config_generic_abi(handle, status),
      uniffiRustCallOptions(),
    );
  },
  cloneHandleRawExternal(handle) {
    const rawExternalCloneHandle = uniffiGetCachedLibraryFunction(
      "uniffi_fixture_basic_fn_clone_config:raw-external",
      (bindings) => bindings.library.func(
        "uniffi_fixture_basic_fn_clone_config",
        bindings.ffiTypes.VoidPointer,
        [bindings.ffiTypes.VoidPointer, koffi.pointer(bindings.ffiTypes.RustCallStatus)],
      ),
    );
    return uniffiRustCaller.rustCall(
      (status) => rawExternalCloneHandle(handle, status),
      uniffiRustCallOptions(),
    );
  },
  cloneHandle(handle) {
    return uniffiRustCaller.rustCall(
      (status) => ffiFunctions.uniffi_fixture_basic_fn_clone_config(handle, status),
      uniffiRustCallOptions(),
    );
  },
  freeHandleGeneric(handle) {
    uniffiRustCaller.rustCall(
      (status) => ffiFunctions.uniffi_fixture_basic_fn_free_config_generic_abi(handle, status),
      uniffiRustCallOptions(),
    );
  },
  freeHandleRawExternal(handle) {
    const rawExternalFreeHandle = uniffiGetCachedLibraryFunction(
      "uniffi_fixture_basic_fn_free_config:raw-external",
      (bindings) => bindings.library.func(
        "uniffi_fixture_basic_fn_free_config",
        "void",
        [bindings.ffiTypes.VoidPointer, koffi.pointer(bindings.ffiTypes.RustCallStatus)],
      ),
    );
    uniffiRustCaller.rustCall(
      (status) => rawExternalFreeHandle(handle, status),
      uniffiRustCallOptions(),
    );
  },
  freeHandle(handle) {
    uniffiRustCaller.rustCall(
      (status) => ffiFunctions.uniffi_fixture_basic_fn_free_config(handle, status),
      uniffiRustCallOptions(),
    );
  },
});
const FfiConverterConfig = createObjectConverter(uniffiConfigObjectFactory);

export class Reader extends UniffiObjectBase {
  constructor() {
    super();
    return uniffiNotImplemented("Reader.constructor");
  }

  label() {
    const loweredSelf = uniffiReaderObjectFactory.cloneHandle(this);
    const ffiMethod =
      uniffiReaderObjectFactory.usesGenericAbi(this)
        ? ffiFunctions.uniffi_fixture_basic_fn_method_reader_label_generic_abi
        : ffiFunctions.uniffi_fixture_basic_fn_method_reader_label;
    const uniffiResult = uniffiRustCaller.rustCall(
      (status) => ffiMethod(loweredSelf, status),
      uniffiRustCallOptions(),
    );
    return uniffiLiftStringFromRustBuffer(uniffiResult);
  }

  async label_async() {
    const loweredSelf = uniffiReaderObjectFactory.cloneHandle(this);
    const ffiMethod =
      uniffiReaderObjectFactory.usesGenericAbi(this)
        ? ffiFunctions.uniffi_fixture_basic_fn_method_reader_label_async_generic_abi
        : ffiFunctions.uniffi_fixture_basic_fn_method_reader_label_async;
    const completeFunc = (rustFuture, status) => ffiFunctions.ffi_fixture_basic_rust_future_complete_rust_buffer(rustFuture, status);
    return rustCallAsync({
      rustFutureFunc: () => ffiMethod(loweredSelf),
      pollFunc: (rustFuture, _continuationCallback, continuationHandle) => ffiFunctions.ffi_fixture_basic_rust_future_poll_rust_buffer(rustFuture, uniffiGetRustFutureContinuationPointer(), continuationHandle),
      cancelFunc: (rustFuture) => ffiFunctions.ffi_fixture_basic_rust_future_cancel_rust_buffer(rustFuture),
      completeFunc,
      freeFunc: (rustFuture) => ffiFunctions.ffi_fixture_basic_rust_future_free_rust_buffer(rustFuture),
      liftFunc: (uniffiResult) => uniffiLiftStringFromRustBuffer(uniffiResult),
      ...uniffiRustCallOptions(),
    });
  }
}

const uniffiReaderObjectFactory = createObjectFactory({
  typeName: "Reader",
  createInstance: () => Object.create(Reader.prototype),
  cloneFreeUsesUniffiHandle: true,
  cloneHandleGeneric(handle) {
    return uniffiRustCaller.rustCall(
      (status) => ffiFunctions.uniffi_fixture_basic_fn_clone_reader_generic_abi(handle, status),
      uniffiRustCallOptions(),
    );
